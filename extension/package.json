{
  "name": "download-router-firefox",
  "version": "0.1.0",
  "description": "Firefox extension that routes downloads into subfolders based on user-defined rules.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "node build.ts",
    "watch": "node build.ts --watch",
    "typecheck": "tsc --noEmit",
    "lint": "web-ext lint --source-dir dist",
    "package": "web-ext build --source-dir dist --artifacts-dir web-ext-artifacts --overwrite-dest",
    "sign": "web-ext sign --source-dir dist --channel listed"
  },
  "devDependencies": {
    "@types/firefox-webext-browser": "^120.0.4",
    "esbuild": "^0.24.0",
    "typescript": "^5.6.3",
    "web-ext": "^8.3.0"
  }
}
